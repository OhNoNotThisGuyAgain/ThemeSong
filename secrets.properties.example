# Copy this file to `secrets.properties` (git-ignored) and fill in your own values.
# These are injected into BuildConfig / the manifest by app/build.gradle.kts.

# From your Spotify Developer Dashboard app (https://developer.spotify.com/dashboard).
SPOTIFY_CLIENT_ID=your_spotify_client_id

# Must be registered EXACTLY as a Redirect URI on the same dashboard app.
SPOTIFY_REDIRECT_URI=spotzones://auth

# Google Maps SDK key with the "Maps SDK for Android" enabled.
MAPS_API_KEY=your_google_maps_android_key
